# Database (Railway MySQL or PlanetScale)
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=3306

# JWT
JWT_SECRET=

# Frontend URL (no trailing slash)
CLIENT_ORIGIN=https://your-frontend-domain.vercel.app

# Public API URL (used for file upload URLs)
PUBLIC_BASE_URL=https://your-backend.up.railway.app

# Resend Email
RESEND_API_KEY=
MAIL_FROM_EMAIL=noreply@yourdomain.com
MAIL_FROM_NAME=Netanix CTF

# Discord Webhooks (optional — notifications disabled if not set)
DISCORD_WEBHOOK_BLOOD=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_CHALLENGE=https://discord.com/api/webhooks/...

# File uploads (Railway Volume mount path, or leave blank for local)
UPLOAD_DIR=
